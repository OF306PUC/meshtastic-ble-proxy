# Zephyr / west build output
build*/

# Meshtastic protobuf definitions — provide locally before building (see README:
# symlink or submodule). Ignored so a machine-specific symlink isn't committed.
# (If you add proto as a git submodule, use `git submodule add --force proto`.)
/proto

# Local session continuity (migrated from studio repo) — never commit to public history
/.session/

# Channel PSKs generated by tools/meshtastic/configure_node.py — SECRET, never commit
tools/meshtastic/channel_psks.txt

# Local secrets: channel PSKs live here (base64). SECRET, never commit.
tools/meshtastic/.env

# Python tooling environments / caches
__pycache__/
*.pyc
.venv/
venv/

# Test scripts
tests*/

# Extra files
readings/
